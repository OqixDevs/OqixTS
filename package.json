{
  "name": "oqixts",
  "version": "1.1.0",
  "description": "Discord BOT intended for FIT@FI server.",
  "main": "index.js",
  "scripts": {
    "start": "ts-node src/index.ts",
    "test": "jest",
    "dev": "nodemon -L --config nodemon.json src/index.ts",
    "prettier-format": "prettier --config .prettierrc 'src/**/*.ts' --write",
    "prettier-check": "prettier --config .prettierrc 'src/**/*.ts' --check",
    "lint": "eslint . --ext .ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OqixDevs/OqixTS.git"
  },
  "keywords": [
    "oqix",
    "oqixts",
    "oqixjs",
    "oqixdevs",
    "fit@fi"
  ],
  "author": "OqixDevs",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/OqixDevs/OqixTS/issues"
  },
  "homepage": "https://github.com/OqixDevs/OqixTS#readme",
  "dependencies": {
    "@discordjs/rest": "2.6.1",
    "@prisma/client": "6.19.3",
    "discord-api-types": "0.38.48",
    "discord.js": "14.26.4",
    "dotenv": "17.4.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@braintree/sanitize-url": "7.1.2",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.1",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "axios": "1.17.0",
    "cheerio": "1.2.0",
    "eslint": "^10.0.0",
    "jest": "30.4.2",
    "jest-mock-extended": "4.0.1",
    "prettier": "3.8.3",
    "prisma": "^6.19.0",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  },
  "optionalDependencies": {
    "nodemon": "3.1.14"
  },
  "prisma": {
    "schema": "src/model/schema.prisma"
  }
}
